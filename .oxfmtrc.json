{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "bracketSameLine": true,
  "trailingComma": "es5",
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/*.md",
    "ios/**/*",
    "android/**/*",
    ".agents/**/*",
    ".claude/**/*",
    "bun.lock",
    "convex/_generated/**/*"
  ]
}
